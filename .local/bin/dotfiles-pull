#!/usr/bin/env bash

set -euo pipefail

if ! [[ $(yadm rev-parse HEAD) = $(yadm ls-remote $(yadm rev-parse --abbrev-ref @{u} | sed 's/\// /g') | cut -f1) ]]; then
    echo Pull needed
    exit 1
fi

