#!/usr/bin/env bash

set -euo pipefail

yadm pull --quiet origin main

if [[ "$(whoami)" != "root" ]]; then
    echo -e "\nEncrypting stuff...\n\n"
    yadm encrypt
fi


if [ -n "$(yadm status --porcelain)" ]; then
    echo -e "\nCommiting...\n\n"
    yadm commit -am "$(curl -sL commit.yatx.one)" && \
    echo -e "\nPushing... \n\n"
    yadm push --quiet origin main
    echo -e "\nDone! \n\n"
else
    echo "\n\nNothing to commit."
fi

