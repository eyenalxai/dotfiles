#!/usr/bin/env bash

set -euo pipefail

if [[ "$(whoami)" != "root" ]]; then
    yadm encrypt
fi


if [ -n "$(yadm status --porcelain)" ]; then
    yadm commit -am "$(curl -sL commit.takx.xyz)" && \
    yadm push --quiet origin main
    echo -e "\nDone!\n\n"
else
    echo "\n\nNothing to commit."
fi

