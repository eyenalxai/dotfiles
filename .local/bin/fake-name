#!/usr/bin/env bash

NAME_PROVIDER_URL="https://name.takx.xyz"

# Create variable SPLIT_USERNAMES and assign true
SPLIT_USERNAMES=false

# Check that jq is installed.
if ! [ -x "$(command -v jq)" ]; then
  echo "jq is not installed. Please install it and try again."
  exit 1
fi

# Ask user if they want to split usernames into two parts. Assign the answer to a variable.
printf "Split usernames into two parts? (y/[n]) "
read -r ANSWER

# If the answer is "y", set SPLIT_USERNAMES to true.
if [[ "${ANSWER}" =~ ^[Yy]$ ]]; then
    SPLIT_USERNAMES=true
fi

# Send GET request using curl to NAME_PROVIDER_URL and receive json response with random usernames inside an json array.
# Assign the response to a variable called USERNAMES_JSON.
USERNAMES_JSON=$(curl -s "${NAME_PROVIDER_URL}")

# Parse the json array and assign the usernames to a variable called USERNAMES.
USERNAMES=$(echo "${USERNAMES_JSON}" | jq -r '.[]')

# Print newline.
printf "\n"

for USERNAME in ${USERNAMES}; do

    # Create an empty array called USERNAME_ARRAY.
    USERNAME_ARRAY=()

    # If SPLIT_USERNAMES is true, split the username into two equal parts, otherwise, just print the username.
    if ${SPLIT_USERNAMES}; then
        # Get the length of the username using #
        USERNAME_LENGTH="${#USERNAME}"

        # Split username into two based on the length of the username.
        USERNAME_FIRST_PART=$(echo "${USERNAME}" | cut -c1-"$((USERNAME_LENGTH/2))")
        USERNAME_SECOND_PART=$(echo "${USERNAME}" | cut -c"$((USERNAME_LENGTH/2+1))"-"$USERNAME_LENGTH")

        # Capitalize first letter of each part using tr command.
        USERNAME_FIRST_PART="$(tr '[:lower:]' '[:upper:]' <<< ${USERNAME_FIRST_PART:0:1})${USERNAME_FIRST_PART:1}"
        USERNAME_SECOND_PART="$(tr '[:lower:]' '[:upper:]' <<< ${USERNAME_SECOND_PART:0:1})${USERNAME_SECOND_PART:1}"

        # Combine the two parts into single string and put them into USERNAME_ARRAY.
        USERNAME_ARRAY+=("${USERNAME_FIRST_PART}${USERNAME_SECOND_PART}")
    else
        # Add the username to USERNAME_ARRAY.
        USERNAME_ARRAY+=("${USERNAME}")
    fi
done

# Print each username in USERNAME_ARRAY with a number next to it.
for ((i=0; i<${#USERNAME_ARRAY[@]}; i++)); do
    printf "%d. %s\n" "$((i+1))" "${USERNAME_ARRAY[$i]}"
done