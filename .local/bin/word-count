#!/usr/bin/env bash

# Check that number of arguments is correct
if [ $# -ne 1 ]; then
    echo "Usage: word-count.sh <text file>"
    exit 1
fi

# Read a single argument from the command line and store it in a variable INPUT_FILE
INPUT_FILE=$1

# Count number of words in the file and print it to the screen
echo "Number of words: $(wc -w < "$INPUT_FILE")"